# baas-env — test-fixture environment template.
# Copy to .env and `source` it before running the e2e (or `set -a; . ./.env; set +a`).
#
# The live-integration e2e targets OpenClaw 2026.5.28 (the /workboard task-flag
# API + FA-CONCURRENCY land there), pinned under Homebrew node@24. createFixture
# already applies this PATH automatically when that openclaw is present (see
# fixturePath() in src/fixture.ts); sourcing it here also makes the surrounding
# test process — and the skip-gate's `openclaw --version` probe — use 2026.5.28.
#
# Override on CI / other machines by exporting BAAS_FIXTURE_PATH instead.
export PATH='/opt/homebrew/opt/node@24/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin'
